# Copy this file to `.env` and fill in the values.
# `.env` is gitignored; `.env.example` is the template that ships with the repo.

# ─── Required ─────────────────────────────────────────────────────────────────

# Used by every project: powers the OpenAI agents, the hosted WebSearchTool
# (deep-researcher), and the openai-agents SDK's tracing dashboard.
OPENAI_API_KEY=

# Required by sdr-agent: the three sales-persona agents run on Claude Sonnet
# via LiteLLM. Not used by deep-researcher.
ANTHROPIC_API_KEY=

# Required by sdr-agent: SendGrid delivers the final cold-outreach email.
# Not used by deep-researcher.
SENDGRID_API_KEY=

# ─── Optional sdr-agent overrides ─────────────────────────────────────────────
# Defaults live in sdr-agent/src/config.py; set these to override.

# Verified single-sender address in your SendGrid account. SendGrid will
# reject sends from any address that isn't verified.
# SDR_FROM_EMAIL=you@example.com

# Recipient of the generated cold email.
# SDR_TO_EMAIL=you@example.com

# Model used for the three sales-persona drafters (Anthropic, via LiteLLM).
# SDR_SALES_MODEL=claude-sonnet-4-6

# Model used for utility sub-agents: subject writer, html converter, guardrails.
# SDR_UTILITY_MODEL=gpt-4o-mini
